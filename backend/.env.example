# ── Supabase ──────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── LiveKit ───────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# ── OpenAI ────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ── AWS S3 (optional) ─────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-recordings-bucket

# ── Google Calendar OAuth ─────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Enable: Google Calendar API
# Authorised redirect URI: http://localhost:5173/integrations/google/callback (and your prod URL)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/integrations/google/callback

# ── Twilio Phone / SIP ────────────────────────────────────
# Run scripts/setup_sip_trunks.py once to generate all values below
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_TRUNK_SID=                          # filled by setup script
LIVEKIT_SIP_INBOUND_TRUNK_ID=              # filled by setup script
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=             # filled by setup script
LIVEKIT_SIP_HOST=                          # from LiveKit Cloud dashboard → Project Settings → SIP URI (e.g. sip:abc123.sip.livekit.cloud)
AGENT_NAME=ai-employee-agent               # must match AGENT_NAME in agent/.env.local
SIP_AUTH_USERNAME=                         # filled by setup script
SIP_AUTH_PASSWORD=                         # filled by setup script
TWILIO_TERM_SIP_USERNAME=                  # filled by setup script
TWILIO_TERM_SIP_PASSWORD=                  # filled by setup script
TWILIO_TERM_DOMAIN=                        # filled by setup script

# ── App ───────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,https://your-lovable-app.com
