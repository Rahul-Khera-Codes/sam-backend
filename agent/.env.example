# LiveKit (same project as backend)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# OpenAI Realtime
OPENAI_API_KEY=

# Supabase (for business/location names in welcome message)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Google Calendar OAuth (same credentials as backend — leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Call recording via LiveKit Egress → Supabase Storage S3
# Get these from Supabase Dashboard → Storage → S3 (generate access key)
# Endpoint format: https://<project-ref>.supabase.co/storage/v1/s3
SUPABASE_STORAGE_URL=
SUPABASE_STORAGE_REGION=us-east-1
SUPABASE_STORAGE_ACCESS_KEY_ID=
SUPABASE_STORAGE_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_BUCKET=call-recordings
